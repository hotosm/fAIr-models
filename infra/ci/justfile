set shell := ["bash", "-euo", "pipefail", "-c"]

ns := "fair"
pgstac_dsn := "postgresql://postgres:postgres@localhost:5432/fair_models"
dev := "../dev"
root := "../.."

[doc('Deploy infra, seed data, register ZenML stack')]
setup:
    #!/usr/bin/env bash
    set -euo pipefail
    kubectl create ns {{ns}} --dry-run=client -o yaml | kubectl apply -f -
    kubectl apply -n {{ns}} -f {{dev}}/postgres/service.yaml -f {{dev}}/postgres/statefulset.yaml
    kubectl rollout status -n {{ns}} statefulset/postgres --timeout=120s
    (cd {{dev}} && helmfile sync --selector name!=nvidia-device-plugin)
    kubectl wait --for=condition=complete job --all -n {{ns}} --timeout=300s
    kubectl rollout status -n {{ns}} deployment/stac-stac --timeout=300s
    kubectl rollout status -n {{ns}} deployment/zenml --timeout=300s
    kubectl rollout status -n {{ns}} deployment/minio --timeout=300s
    kubectl rollout status -n {{ns}} deployment/mlflow --timeout=300s
    while read -r svc ports; do
        kubectl port-forward -n {{ns}} "svc/$svc" "$ports" &
    done < {{dev}}/ports.conf
    while read -r svc ports; do
        for i in $(seq 1 30); do nc -z localhost "${ports%%:*}" 2>/dev/null && break; sleep 1; done
    done < {{dev}}/ports.conf
    uv run --with minio python {{dev}}/scripts/seed_data.py
    cd {{root}}
    uv run zenml init
    for i in 1 2 3 4 5; do
        uv run zenml connect --url http://localhost:8080 --username default --password '' --no-verify-ssl && break
        echo "zenml connect: attempt $i failed, retrying in 5s..." >&2
        sleep 5
    done
    uv run zenml stack import ci-k8s -f stacks/ci-k8s.yaml --ignore-version-mismatch || true
    uv run zenml stack set ci-k8s

[doc('Run E2E pipeline against k8s infra')]
run-example:
    #!/usr/bin/env bash
    set -euo pipefail
    cd {{root}}
    AWS_ENDPOINT_URL=http://localhost:9000 \
    FAIR_FORCE_CPU=1 \
        uv run python examples/unet/run.py all \
            --stac-api-url http://localhost:8082 \
            --dsn "{{pgstac_dsn}}"
