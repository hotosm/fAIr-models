# DigitalOcean API token (https://cloud.digitalocean.com/account/api/tokens)
DO_TOKEN=

# Cluster
CLUSTER_NAME=fair
DO_REGION=nyc3
INFRA_NODE_SIZE=s-2vcpu-4gb
ML_NODE_SIZE=s-4vcpu-8gb

# Domain (wildcard *.FAIR_DOMAIN -> LB IP via `just deploy`)
FAIR_DOMAIN=

# Managed PostgreSQL (auto-populated by `just infra`)
PG_HOST=
PG_PORT=25060
PG_USER=
PG_PASSWORD=

# Auth (admin credentials for MLflow and ZenML dashboards)
MLFLOW_ADMIN_USER=
MLFLOW_ADMIN_PASSWORD=
ZENML_ADMIN_USER=
ZENML_ADMIN_PASSWORD=

# HTTPS (Let's Encrypt certificate email)
LETSENCRYPT_EMAIL=

# DO Spaces (https://cloud.digitalocean.com/account/api/spaces)
SPACES_BUCKET=
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
