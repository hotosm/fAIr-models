set shell := ["bash", "-euo", "pipefail", "-c"]
set dotenv-load

ns := "fair"
scripts := "scripts"
infra_node_size := env("INFRA_NODE_SIZE", "s-2vcpu-4gb")
required_vars := "DO_TOKEN FAIR_DOMAIN MLFLOW_ADMIN_USER MLFLOW_ADMIN_PASSWORD ZENML_ADMIN_USER ZENML_ADMIN_PASSWORD LETSENCRYPT_EMAIL SPACES_BUCKET SPACES_ACCESS_KEY SPACES_SECRET_KEY"

[doc('Provision infra, deploy, configure DNS')]
up:
    #!/usr/bin/env bash
    set -euo pipefail
    {{ scripts }}/cluster.sh create
    {{ scripts }}/database.sh create
    {{ scripts }}/database.sh firewall
    {{ scripts }}/database.sh write-env
    {{ scripts }}/spaces.sh create
    set -a && source .env && set +a
    source {{ scripts }}/env-derived.sh
    {{ scripts }}/database.sh init
    just _validate-env
    {{ scripts }}/deploy.sh helm
    {{ scripts }}/deploy.sh cert-issuer
    {{ scripts }}/deploy.sh stac-ingress
    {{ scripts }}/deploy.sh dns
    {{ scripts }}/spaces.sh seed
    {{ scripts }}/deploy.sh register-stack
    echo "ZenML:  https://zenml.${FAIR_DOMAIN}"
    echo "MLflow: https://mlflow.${FAIR_DOMAIN}"
    echo "STAC:   https://stac.${FAIR_DOMAIN}/stac"

[doc('Provision cloud infrastructure only')]
infra:
    #!/usr/bin/env bash
    set -euo pipefail
    {{ scripts }}/cluster.sh create
    {{ scripts }}/database.sh create
    {{ scripts }}/database.sh write-env
    {{ scripts }}/spaces.sh create
    {{ scripts }}/database.sh init

[doc('Deploy services (requires .env to be populated)')]
deploy:
    #!/usr/bin/env bash
    set -euo pipefail
    {{ scripts }}/database.sh write-env
    set -a && source .env && set +a
    source {{ scripts }}/env-derived.sh
    just _validate-env
    {{ scripts }}/deploy.sh helm
    {{ scripts }}/deploy.sh cert-issuer
    {{ scripts }}/deploy.sh stac-ingress
    {{ scripts }}/deploy.sh dns
    {{ scripts }}/spaces.sh seed
    {{ scripts }}/deploy.sh register-stack
    just urls

[doc('Destroy cluster and database (keeps Spaces bucket)')]
tear:
    #!/usr/bin/env bash
    set -euo pipefail
    export FAIR_LABEL_DOMAIN="${FAIR_DOMAIN:-}"
    export DOKS_CONTEXT="do-${DO_REGION:-nyc3}-${CLUSTER_NAME:-fair}"
    export SPACES_ENDPOINT="https://${DO_REGION:-nyc3}.digitaloceanspaces.com"
    helmfile destroy 2>/dev/null || true
    {{ scripts }}/database.sh delete || true
    {{ scripts }}/cluster.sh delete || true
    ENV_FILE="$(cd "$(dirname "$0")" && pwd)/.env"
    if [[ -f "$ENV_FILE" ]]; then
      sed -i.bak \
        -e 's|^PG_HOST=.*|PG_HOST=|' \
        -e 's|^PG_PORT=.*|PG_PORT=25060|' \
        -e 's|^PG_USER=.*|PG_USER=|' \
        -e 's|^PG_PASSWORD=.*|PG_PASSWORD=|' "$ENV_FILE"
      rm -f "$ENV_FILE.bak"
      echo "PG credentials cleared from .env"
    fi
    echo "Spaces bucket ${SPACES_BUCKET:-} preserved. Delete manually if needed."

[doc('Show cluster health')]
status:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Cluster:  $(doctl kubernetes cluster get "${CLUSTER_NAME:-fair}" --format Status --no-header 2>/dev/null || echo 'not found')"
    echo "Database: $(doctl databases list --format Status --no-header 2>/dev/null | head -1 || echo 'not found')"
    echo "Pods:"
    kubectl get pods -n {{ ns }} --no-headers 2>/dev/null | sed 's/^/  /' || echo "  no context"
    echo ""
    just urls 2>/dev/null || true

[doc('Print service URLs')]
urls:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "ZenML:  https://zenml.${FAIR_DOMAIN}"
    echo "MLflow: https://mlflow.${FAIR_DOMAIN}"
    echo "STAC:   https://stac.${FAIR_DOMAIN}/stac"

[doc('Submit all pipelines to cluster')]
run-example:
    #!/usr/bin/env bash
    set -euo pipefail
    {{ scripts }}/database.sh write-env
    set -a && source .env && set +a
    source {{ scripts }}/env-derived.sh
    echo "Checking database connectivity..."
    psql "$PGSTAC_DSN" -c "SELECT 1" >/dev/null
    echo "Database: ok"
    TOKEN=$({{ scripts }}/zenml-token.sh)
    cd ../..
    for example in segmentation classification detection; do
        ZENML_STORE_URL="https://zenml.${FAIR_DOMAIN}" \
        ZENML_STORE_API_TOKEN="$TOKEN" \
        FAIR_FORCE_CPU=1 \
        FAIR_DSN="$PGSTAC_DSN" \
        FAIR_STAC_API_URL="$STAC_API_URL" \
        FAIR_LABEL_DOMAIN="$FAIR_LABEL_DOMAIN" \
        FAIR_UPLOAD_ARTIFACTS=true \
        AWS_ENDPOINT_URL="$SPACES_ENDPOINT" \
        AWS_ACCESS_KEY_ID="${SPACES_ACCESS_KEY}" \
        AWS_SECRET_ACCESS_KEY="${SPACES_SECRET_KEY}" \
        uv run python "examples/$example/run.py"
    done

[private]
_validate-env:
    #!/usr/bin/env bash
    set -euo pipefail
    missing=()
    for var in {{ required_vars }}; do
      [[ -n "${!var:-}" ]] || missing+=("$var")
    done
    if (( ${#missing[@]} > 0 )); then
      echo "ERROR: Missing required environment variables:"
      printf '  %s\n' "${missing[@]}"
      echo "Copy env.example to .env and fill in the values."
      exit 1
    fi
