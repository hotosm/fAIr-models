set shell := ["bash", "-euo", "pipefail", "-c"]

ns := "fair"
env := ".env"

[doc('Initialize OpenTofu')]
init:
    tofu init

[doc('Preview changes')]
plan:
    tofu plan

[doc('Provision infra, deploy services, configure post-deploy')]
up:
    #!/usr/bin/env bash
    set -euo pipefail
    tofu apply -auto-approve
    just _write-env
    just _save-kubeconfig
    just _cluster-issuer
    just _db-init
    just _seed
    just _register-stack
    just urls

[doc('Destroy all resources (keeps Spaces bucket data)')]
tear:
    tofu destroy -auto-approve

[doc('Show cluster health')]
status:
    #!/usr/bin/env bash
    set -euo pipefail
    just urls 2>/dev/null || echo "No tofu state yet."
    echo "Pods:"
    kubectl get pods -n {{ ns }} --no-headers 2>/dev/null | sed 's/^/  /' || echo "  no context"

[doc('Print service URLs')]
urls:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "ZenML:  $(tofu output -raw zenml_url)"
    echo "MLflow: $(tofu output -raw mlflow_url)"
    echo "STAC:   $(tofu output -raw stac_url)"

[doc('Submit all pipelines to cluster')]
run-example:
    #!/usr/bin/env bash
    set -euo pipefail
    set -a && source {{ env }} && set +a
    echo "Checking database connectivity..."
    psql "$PGSTAC_DSN" -c "SELECT 1" >/dev/null
    echo "Database: ok"
    TOKEN=$(scripts/zenml-token.sh)
    cd ../..
    for example in segmentation classification detection; do
        ZENML_STORE_URL="https://zenml.${FAIR_DOMAIN}" \
        ZENML_STORE_API_TOKEN="$TOKEN" \
        ZENML_STORE_VERIFY_SSL=false \
        FAIR_FORCE_CPU=1 \
        FAIR_DSN="$PGSTAC_DSN" \
        FAIR_STAC_API_URL="$STAC_URL" \
        FAIR_LABEL_DOMAIN="$FAIR_DOMAIN" \
        FAIR_UPLOAD_ARTIFACTS=true \
        AWS_ENDPOINT_URL="$SPACES_ENDPOINT" \
        AWS_ACCESS_KEY_ID="$SPACES_ACCESS_KEY" \
        AWS_SECRET_ACCESS_KEY="$SPACES_SECRET_KEY" \
        uv run --group example python "examples/$example/run.py"
    done

# ---- Internal ----

[private]
_write-env:
    tofu output -json | jq -r 'to_entries[] | "\(.key | ascii_upcase)=\(.value.value)"' > {{ env }}
    @echo ".env written from tofu outputs."

[private]
_save-kubeconfig:
    #!/usr/bin/env bash
    set -euo pipefail
    set -a && source {{ env }} && set +a
    doctl kubernetes cluster kubeconfig save "$(echo "$DOKS_CONTEXT" | sed 's/^do-[^-]*-//')"

[private]
_cluster-issuer:
    #!/usr/bin/env bash
    set -euo pipefail
    set -a && source {{ env }} && set +a
    sed "s/LETSENCRYPT_EMAIL/$LETSENCRYPT_EMAIL/" cluster-issuer.yaml | kubectl apply -f -

[private]
_db-init:
    #!/usr/bin/env bash
    set -euo pipefail
    set -a && source {{ env }} && set +a
    FAIR_URI=$(echo "$PG_URI" | sed 's|/defaultdb|/fair_models|')
    psql "$FAIR_URI" -c "CREATE EXTENSION IF NOT EXISTS postgis; CREATE EXTENSION IF NOT EXISTS btree_gist;" 2>/dev/null
    echo "Extensions installed."
    uv run --extra k8s pypgstac migrate --dsn "$FAIR_URI"
    echo "pgstac migration complete."

[private]
_seed:
    #!/usr/bin/env bash
    set -euo pipefail
    set -a && source {{ env }} && set +a
    AWS_ENDPOINT_URL="$SPACES_ENDPOINT" \
    AWS_ACCESS_KEY_ID="$SPACES_ACCESS_KEY" \
    AWS_SECRET_ACCESS_KEY="$SPACES_SECRET_KEY" \
    SPACES_BUCKET="$SPACES_BUCKET" \
    uv run --with boto3 python scripts/seed_data.py

[private]
_register-stack:
    #!/usr/bin/env bash
    set -euo pipefail
    set -a && source {{ env }} && set +a
    TOKEN=$(scripts/zenml-token.sh --wait)
    export ZENML_STORE_URL="https://zenml.${FAIR_DOMAIN}"
    export ZENML_STORE_API_TOKEN="$TOKEN"
    export ZENML_STORE_VERIFY_SSL=false
    RESOLVED=".dok8s-stack-resolved.yaml"
    envsubst < ../../stacks/dok8s.yaml > "$RESOLVED"
    uv run zenml stack import dok8s -f "$RESOLVED" --ignore-version-mismatch 2>/dev/null || true
    uv run zenml stack set dok8s
    rm -f "$RESOLVED"
