{
    "type": "Feature",
    "stac_version": "1.1.0",
    "stac_extensions": [
        "https://stac-extensions.github.io/mlm/v1.5.1/schema.json",
        "https://stac-extensions.github.io/version/v1.2.0/schema.json",
        "https://stac-extensions.github.io/classification/v2.0.0/schema.json",
        "https://stac-extensions.github.io/file/v2.1.0/schema.json",
        "https://stac-extensions.github.io/raster/v1.1.0/schema.json"
    ],
    "id": "resnet18-classification",
    "geometry": {
        "type": "Polygon",
        "coordinates": [
            [
                [
                    -180,
                    -90
                ],
                [
                    180,
                    -90
                ],
                [
                    180,
                    90
                ],
                [
                    -180,
                    90
                ],
                [
                    -180,
                    -90
                ]
            ]
        ]
    },
    "bbox": [
        -180,
        -90,
        180,
        90
    ],
    "properties": {
        "datetime": "2024-01-01T00:00:00Z",
        "title": "ResNet18 Building Classification",
        "description": "ResNet18 binary classification model for building presence detection in aerial imagery chips. Pretrained on ImageNet via torchvision, intended for finetuning on OAM + OSM derived classification labels.",
        "mlm:name": "resnet18-classification",
        "mlm:architecture": "ResNet",
        "mlm:tasks": [
            "classification"
        ],
        "mlm:framework": "PyTorch",
        "mlm:framework_version": "2.10.0",
        "mlm:pretrained": true,
        "mlm:pretrained_source": "https://pytorch.org/vision/main/models/generated/torchvision.models.resnet18.html",
        "mlm:accelerator": "amd64",
        "mlm:accelerator_count": 1,
        "keywords": [
            "building",
            "classification",
            "polygon"
        ],
        "license": "AGPL-3.0-only",
        "version": "1",
        "fair:metrics_spec": [
            {
                "key": "fair:accuracy",
                "name": "Accuracy",
                "description": "Fraction of correctly classified chips"
            },
            {
                "key": "fair:precision",
                "name": "Precision",
                "description": "Fraction of predicted building chips that are actually buildings"
            },
            {
                "key": "fair:recall",
                "name": "Recall",
                "description": "Fraction of actual building chips correctly identified"
            },
            {
                "key": "fair:f1",
                "name": "F1 Score",
                "description": "Harmonic mean of precision and recall"
            }
        ],
        "mlm:input": [
            {
                "name": "RGB chips",
                "bands": [
                    {
                        "name": "red"
                    },
                    {
                        "name": "green"
                    },
                    {
                        "name": "blue"
                    }
                ],
                "input": {
                    "shape": [
                        -1,
                        3,
                        256,
                        256
                    ],
                    "dim_order": [
                        "batch",
                        "bands",
                        "height",
                        "width"
                    ],
                    "data_type": "float32"
                },
                "pre_processing_function": {
                    "format": "python",
                    "expression": "models.resnet18_classification.pipeline:preprocess"
                }
            }
        ],
        "mlm:output": [
            {
                "name": "building probability",
                "tasks": [
                    "classification"
                ],
                "result": {
                    "shape": [
                        -1,
                        1
                    ],
                    "dim_order": [
                        "batch",
                        "class"
                    ],
                    "data_type": "float32"
                },
                "classification:classes": [
                    {
                        "name": "no_building",
                        "value": 0,
                        "description": "No building present in chip"
                    },
                    {
                        "name": "building",
                        "value": 1,
                        "description": "Building present in chip"
                    }
                ],
                "post_processing_function": {
                    "format": "python",
                    "expression": "models.resnet18_classification.pipeline:postprocess"
                },
                "bands": []
            }
        ],
        "mlm:hyperparameters": {
            "epochs": 5,
            "batch_size": 8,
            "learning_rate": 0.001,
            "weight_decay": 0.0001,
            "chip_size": 256,
            "optimizer": "AdamW",
            "loss": "BCEWithLogitsLoss"
        }
    },
    "assets": {
        "model": {
            "href": "torchvision.models.ResNet18_Weights.IMAGENET1K_V1",
            "title": "Pretrained weights (torchvision enum reference, not a URL)",
            "type": "application/octet-stream; framework=pytorch",
            "roles": [
                "mlm:model"
            ],
            "mlm:artifact_type": "torch.save",
            "raster:bands": [
                {
                    "name": "red"
                },
                {
                    "name": "green"
                },
                {
                    "name": "blue"
                }
            ]
        },
        "source-code": {
            "href": "https://github.com/hotosm/fAIr-models/tree/main/models/resnet18_classification",
            "type": "text/html",
            "roles": [
                "code"
            ],
            "mlm:entrypoint": "models.resnet18_classification.pipeline:training_pipeline"
        },
        "mlm:training": {
            "href": "ghcr.io/hotosm/fair-models/resnet18_classification:latest",
            "type": "application/vnd.oci.image.index.v1+json",
            "title": "Training Docker Image",
            "roles": [
                "mlm:training-runtime"
            ]
        },
        "mlm:inference": {
            "href": "ghcr.io/hotosm/fair-models/resnet18_classification:latest",
            "type": "application/vnd.oci.image.index.v1+json",
            "title": "Inference Docker Image",
            "roles": [
                "mlm:inference-runtime"
            ]
        },
        "readme": {
            "href": "https://raw.githubusercontent.com/hotosm/fAIr-models/refs/heads/main/models/resnet18_classification/README.md",
            "type": "text/markdown",
            "roles": [
                "metadata"
            ],
            "title": "Model README"
        }
    },
    "links": [
        {
            "rel": "license",
            "href": "https://www.gnu.org/licenses/agpl-3.0.html",
            "type": "text/html",
            "title": "GNU Affero General Public License v3.0"
        }
    ]
}