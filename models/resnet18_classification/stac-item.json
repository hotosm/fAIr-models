                "key": "fair:accuracy",
                "name": "Accuracy",
                "description": "Fraction of correctly classified chips"
            },
            {
                "key": "fair:precision",
                "name": "Precision",
                "description": "Fraction of predicted building chips that are actually buildings"
            },
            {
                "key": "fair:recall",
                "name": "Recall",
                "description": "Fraction of actual building chips correctly identified"
            },
            {
                "key": "fair:f1",
                "name": "F1 Score",
                "description": "Harmonic mean of precision and recall"
            }
        ],
