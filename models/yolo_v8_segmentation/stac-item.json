        "title": "YOLOv8 Building Footprint Segmentation",
        "description": "YOLOv8 segmentation base model for extracting building footprints from RGB aerial imagery, with geospatial preprocessing and polygon postprocessing integrated for fAIr finetuning and inference workflows.",
        "mlm:name": "yolo-v8-segmentation",
        "mlm:architecture": "YOLOv8-Seg",
        "mlm:tasks": [
            "instance-segmentation"
        ],
        "mlm:framework": "PyTorch",
        "mlm:framework_version": "2.10.0",
        "mlm:pretrained": true,
        "mlm:pretrained_source": "https://github.com/hotosm/fAIr-utilities/raw/refs/heads/master/yolov8s_v2-seg.pt",
        "mlm:accelerator": "amd64",
        "mlm:accelerator_count": 1,
        "keywords": [
            "building",
            "instance-segmentation",
            "polygon"
        ],
        "license": "Apache-2.0",
        "version": "2",
        "deprecated": false,
        "fair:metrics_spec": [
            {
                "key": "fair:accuracy",
                "name": "mAP50 (Segmentation)",
                "description": "Segmentation mean Average Precision at IoU 0.50 from YOLO validation."
            },
            {
                "key": "fair:mean_iou",
                "name": "mAP50-95 (Segmentation)",
                "description": "Segmentation mean Average Precision averaged from IoU 0.50 to 0.95."
            },
            {
                "key": "fair:precision",
                "name": "Precision",
                "description": "Segmentation precision across all classes."
            },
            {
                "key": "fair:recall",
                "name": "Recall",
                "description": "Segmentation recall across all classes."
            }
        ],
        "mlm:input": [
            {
                "name": "RGB chips",
                "bands": [
                    {
                        "name": "red"
                    },
                    {
                        "name": "green"
                    },
                    {
                        "name": "blue"
                    }
                ],
                "input": {
                    "shape": [
                        -1,
                        3,
                        256,
                        256
                    ],
                    "dim_order": [
                        "batch",
                        "bands",
                        "height",
                        "width"
                    ],
                    "data_type": "float32"
                },
                "pre_processing_function": {
                    "format": "python",
                    "expression": "models.yolo_v8_segmentation.pipeline:preprocess"
                }
            }
        ],
        "mlm:output": [
            {
                "name": "building masks",
                "tasks": [
                    "instance-segmentation"
                ],
                "result": {
                    "shape": [
                        -1,
                        1,
                        256,
                        256
                    ],
                    "dim_order": [
                        "batch",
                        "channel",
                        "height",
                        "width"
                    ],
                    "data_type": "uint8"
                },
                "classification:classes": [
                    {
                        "name": "background",
                        "value": 0,
                        "description": "Non-building pixels."
                    },
                    {
                        "name": "building",
                        "value": 1,
                        "description": "Building footprint pixels."
                    }
                ],
                "post_processing_function": {
                    "format": "python",
                    "expression": "models.yolo_v8_segmentation.pipeline:postprocess"
                },
                "bands": []
            }
        ],
        "mlm:hyperparameters": {
            "epochs": 20,
            "batch_size": 16,
            "imgsz": 256,
            "pc": 2.0,
            "val_ratio": 0.2,
            "split_seed": 42
        },
        "fair:split_spec": {
            "strategy": "random",
            "default_ratio": 0.2,
            "seed": 42,
            "description": "Preprocess chips and labels, then apply seeded YOLO train/validation split."
