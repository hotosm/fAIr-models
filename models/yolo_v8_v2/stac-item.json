{
    "type": "Feature",
    "stac_version": "1.0.0",
    "stac_extensions": [
        "https://stac-extensions.github.io/mlm/v1.5.1/schema.json",
        "https://stac-extensions.github.io/version/v1.2.0/schema.json",
        "https://stac-extensions.github.io/classification/v2.0.0/schema.json",
        "https://stac-extensions.github.io/file/v2.1.0/schema.json",
        "https://stac-extensions.github.io/raster/v1.1.0/schema.json"
    ],
    "id": "yolo-v8-v2",
    "geometry": {
        "type": "Polygon",
        "coordinates": [
            [
                [-180, -90],
                [180, -90],
                [180, 90],
                [-180, 90],
                [-180, -90]
            ]
        ]
    },
    "bbox": [-180, -90, 180, 90],
    "properties": {
        "datetime": "2024-01-01T00:00:00Z",
        "mlm:name": "yolo-v8-v2",
        "mlm:architecture": "YOLOv8-Seg",
        "mlm:tasks": [
            "instance-segmentation"
        ],
        "mlm:framework": "pytorch",
        "mlm:framework_version": "2.1.0",
        "mlm:pretrained": true,
        "mlm:pretrained_source": "https://github.com/hotosm/fAIr-utilities/raw/refs/heads/master/yolov8s_v2-seg.pt",
        "keywords": [
            "building",
            "instance-segmentation",
            "polygon"
        ],
        "version": "2",
        "mlm:input": [
            {
                "name": "RGB chips",
                "bands": [
                    {"name": "red"},
                    {"name": "green"},
                    {"name": "blue"}
                ],
                "input": {
                    "shape": [-1, 3, 256, 256],
                    "dim_order": ["batch", "bands", "height", "width"],
                    "data_type": "float32"
                },
                "pre_processing_function": {
                    "format": "python",
                    "expression": "models.yolo_v8_v2.pipeline:preprocess"
                }
            }
        ],
        "mlm:output": [
            {
                "name": "binary building mask",
                "tasks": ["instance-segmentation"],
                "result": {
                    "shape": [-1, 1, 256, 256],
                    "dim_order": ["batch", "channel", "height", "width"],
                    "data_type": "uint8"
                },
                "classification:classes": [
                    {
                        "name": "background",
                        "value": 0,
                        "description": "Non-building pixels"
                    },
                    {
                        "name": "building",
                        "value": 1,
                        "description": "Building footprint pixels (instances merged to binary mask)"
                    }
                ],
                "post_processing_function": {
                    "format": "python",
                    "expression": "models.yolo_v8_v2.pipeline:postprocess"
                }
            }
        ],
        "mlm:hyperparameters": {
            "epochs": 20,
            "batch_size": 16,
            "imgsz": 256,
            "pc": 2.0,
            "mosaic": 0.0,
            "overlap_mask": false,
            "cls": 0.5,
            "degrees": 30.0,
            "backbone": "yolov8s-seg",
            "multimasks": true,
            "p_val": 0.05
        }
    },
    "assets": {
        "model": {
            "href": "https://github.com/hotosm/fAIr-utilities/raw/refs/heads/master/yolov8s_v2-seg.pt",
            "type": "application/octet-stream; framework=pytorch",
            "title": "YOLOv8s-v2 base weights (.pt)",
            "roles": ["mlm:model"],
            "mlm:artifact_type": "torch.save",
            "raster:bands": [
                {"name": "red"},
                {"name": "green"},
                {"name": "blue"}
            ]
        },
        "source-code": {
            "href": "https://github.com/hotosm/fAIr-models/tree/main/models/yolo_v8_v2",
            "type": "text/html",
            "title": "YOLOv8-v2 model pack source",
            "roles": ["code"],
            "mlm:entrypoint": "models.yolo_v8_v2.pipeline:training_pipeline",
            "mlm:inference_entrypoint": "models.yolo_v8_v2.pipeline:inference_pipeline"
        },
        "mlm:training": {
            "href": "local",
            "type": "text/plain",
            "title": "Training runtime (Docker)",
            "roles": ["mlm:training-runtime", "runtime"]
        },
        "mlm:inference": {
            "href": "local",
            "type": "text/plain",
            "title": "Inference runtime (Docker)",
            "roles": ["mlm:inference-runtime", "runtime"]
        }
    },
    "links": []
}
