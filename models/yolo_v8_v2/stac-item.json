                [-180, 90],
                [-180, -90]
            ]
        ]
    },
    "bbox": [-180, -90, 180, 90],
    "properties": {
        "datetime": "2024-01-01T00:00:00Z",
        "mlm:name": "yolo-v8-v2",
        "mlm:architecture": "YOLOv8-Seg",
        "mlm:tasks": [
            "instance-segmentation"
        ],
        "mlm:framework": "PyTorch",
        "mlm:framework_version": "2.1.0",
        "mlm:pretrained": true,
        "mlm:pretrained_source": "https://github.com/hotosm/fAIr-utilities/raw/refs/heads/master/yolov8s_v2-seg.pt",
        "keywords": [
            "building",
            "instance-segmentation",
            "polygon"
        ],
        "version": "2",
        "license": "Apache-2.0",
        "status": "active",
        "mlm:total_parameters": 11000000,
        "mlm:memory_size": 536870912,
        "mlm:accelerator": null,
        "mlm:accelerator_constrained": false,
        "licenses": {
            "model": "Apache-2.0",
            "data": "ODbL-1.0",
            "code": "Apache-2.0"
        },
        "inference_time_per_256x256": {
            "value": 25,
            "unit": "ms"
        },
        "pipeline_input": {
            "type": "directory",
            "description": "Directory of raw PNG/TIF chips and labels.geojson (OAM format)",
            "expected_files": "*.png",
            "required_params": ["input_path", "model_uri"]
        },
        "pipeline_output": {
            "type": "file",
            "description": "Single GeoJSON file with merged building footprints (EPSG:4326)",
            "expected_files": "*.geojson",
            "geometry_types": ["Polygon", "MultiPolygon"]
        },
        "evaluation_metrics": [
            {
                "metric": "iou_accuracy_pct",
                "definition": "IoU-based accuracy from Ultralytics YOLOv8 validation",
                "value": 0.85
            }
        ],
        "zenml_entrypoints": {
            "preprocessing": "models.yolo_v8_v2.pipeline:run_preprocessing",
            "inference": "models.yolo_v8_v2.pipeline:inference_pipeline",
            "postprocessing": "models.yolo_v8_v2.pipeline:run_postprocessing",
            "training": "models.yolo_v8_v2.pipeline:train_model"
        },
        "training_time": {
            "value": 2.0,
            "unit": "hours"
        },
        "mlm:input": [
            {
                "name": "RGB chips",
                "bands": [
                    {"name": "red"},
                    {"name": "green"},
                    {"name": "blue"}
                ],
                "input": {
                    "shape": [-1, 3, 256, 256],
                    "dim_order": ["batch", "bands", "height", "width"],
                    "data_type": "float32"
                },
                "pre_processing_function": {
                    "format": "python",
                    "expression": "models.yolo_v8_v2.pipeline:preprocess"
                }
            }
        ],
        "mlm:output": [
            {
                "name": "binary building mask",
                "tasks": ["instance-segmentation"],
                "result": {
                    "shape": [-1, 1, 256, 256],
                    "dim_order": ["batch", "channel", "height", "width"],
                    "data_type": "uint8"
                },
                "classification:classes": [
                    {
                        "name": "background",
                        "value": 0,
                        "description": "Non-building pixels"
                    },
                    {
                        "name": "building",
                        "value": 1,
                        "description": "Building footprint pixels (instances merged to binary mask)"
                    }
                ],
                "post_processing_function": {
                    "format": "python",
                    "expression": "models.yolo_v8_v2.pipeline:postprocess"
                }
            }
        ],
        "mlm:hyperparameters": {
            "epochs": 20,
            "batch_size": 16,
            "imgsz": 256,
            "pc": 2.0,
            "mosaic": 0.0,
            "overlap_mask": false,
            "cls": 0.5,
            "degrees": 30.0,
            "backbone": "yolov8s-seg",
            "multimasks": true,
            "p_val": 0.05,
            "split_seed": 42
        }
    },
    "assets": {
        "model": {
            "href": "https://github.com/hotosm/fAIr-utilities/raw/refs/heads/master/yolov8s_v2-seg.pt",
